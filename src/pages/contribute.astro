---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContributeBuilder from '../components/ContributeBuilder.svelte';
---

<BaseLayout title="Contribute" description="Compose a new entry and open it as a GitHub pull request or issue, no setup required.">
  <div class="content-wide">
    <div class="eyebrow">Contribute</div>
    <h1 class="page-title">Compose an entry.</h1>
    <p class="page-subhead">
      Fill in the fields and watch the <code>.mdx</code> build on the right, then open it straight as a
      pull request (one click, or copy and paste if it runs long) or as an issue if you would rather not
      touch a fork. Your draft is saved in this browser as you type.
    </p>
    <ContributeBuilder client:load />
  </div>
</BaseLayout>
